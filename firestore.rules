rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: ebooks
    // Document ID: auto-generated
    // Fields:
    //   - title: string
    //   - description: string
    //   - heroImage: string
    //   - ctaText: string
    //   - accessCode: string
    //
    // Collection: ebooks/{ebookId}/pages
    // Document ID: auto-generated
    // Fields:
    //   - pageNumber: number
    //   - images: list of strings
    //   - text: string (optional)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidEbook() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'description', 'heroImage', 'ctaText', 'accessCode']) &&
             data.title is string && data.title.size() < 1000 &&
             data.description is string && data.description.size() < 50000 &&
             data.heroImage is string && data.heroImage.size() < 100000 &&
             data.ctaText is string && data.ctaText.size() < 500 &&
             data.accessCode is string && data.accessCode.size() < 100;
    }

    function isValidEbookPage() {
      let data = request.resource.data;
      return data.keys().hasAll(['pageNumber', 'images']) &&
             data.pageNumber is number && data.pageNumber >= 0 &&
             data.images is list && data.images.size() <= 50 &&
             (!('text' in data) || (data.text is string && data.text.size() < 10000));
    }

    match /ebooks/{ebookId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidEbook();
      allow delete: if isAuthenticated();
      
      match /pages/{pageId} {
        allow read: if true;
        allow create, update: if isAuthenticated() && isValidEbookPage();
        allow delete: if isAuthenticated();
      }
    }
  }
}
